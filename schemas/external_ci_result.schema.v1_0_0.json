{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "eml-gr-external-ci-result/1.0.0",
  "title": "EML-GR external CI result v1.0.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "proof_target_id",
    "status",
    "tool",
    "command",
    "raw_log",
    "target_source_sha256",
    "artifact_package_sha256",
    "provenance",
    "result_hash"
  ],
  "properties": {
    "schema_version": {
      "const": "eml-gr-external-ci-result/1.0.0"
    },
    "proof_target_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "compiled_pass",
        "compiled_fail",
        "skipped"
      ]
    },
    "skip_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "argv",
        "exit_code"
      ],
      "properties": {
        "argv": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exit_code": {
          "type": "integer"
        }
      }
    },
    "raw_log": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "target_source_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "artifact_package_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "real_external_run",
        "run_url",
        "commit_sha",
        "run_id",
        "run_attempt",
        "repository",
        "ref_name",
        "actor"
      ],
      "properties": {
        "kind": {
          "enum": [
            "external_ci",
            "local_fixture",
            "local_simulation"
          ]
        },
        "real_external_run": {
          "type": "boolean"
        },
        "run_url": {
          "type": [
            "string",
            "null"
          ]
        },
        "commit_sha": {
          "type": "string"
        },
        "run_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "run_attempt": {
          "type": [
            "string",
            "null"
          ]
        },
        "repository": {
          "type": [
            "string",
            "null"
          ]
        },
        "ref_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "actor": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "result_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{16}$"
    }
  }
}